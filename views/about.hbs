<div class="contact-container">
    <h2>Contact Me</h2>
    
    <div class="contact-card">
        <div class="contact-item">
            <div class="contact-icon">📧</div>
            <div class="contact-details">
                <h4>Email</h4>
                <p>{{email}}</p>
            </div>
        </div>
        
        <div class="contact-item">
            <div class="contact-icon">📱</div>
            <div class="contact-details">
                <h4>Phone</h4>
                <p>{{phone}}</p>
            </div>
        </div>
        
        <div class="contact-item">
            <div class="contact-icon">📍</div>
            <div class="contact-details">
                <h4>Address</h4>
                <p>{{address}}</p>
            </div>
        </div>
    </div>
    
    <div class="social-links">
        <h3>Find me on</h3>
        <div class="social-icons">
            <a href="#">LinkedIn</a>
            <a href="#">GitHub</a>
            <a href="#">Instagram</a>
        </div>
    </div>
</div>